
# Postgres
POSTGRES_USER=email_service
POSTGRES_PASSWORD=email_service_pass
POSTGRES_DB=email_service

# Container-to-container URL for Docker Compose / Traefik deployments.
# If you run Nuxt directly on your host instead of in Docker, change this to localhost
# and publish the database port yourself.
DATABASE_URL=postgresql://email_service:email_service_pass@postgres:5432/email_service

# Redis
# Container-to-container URL for Docker Compose / Traefik deployments.
# If you run Nuxt directly on your host instead of in Docker, change this to localhost
# and publish the Redis port yourself.
REDIS_URL=redis://redis:6379

# Email Provider: nodemailer | resend | sendgrid | mailchimp | postal
EMAIL_PROVIDER=nodemailer

# Resend (for EMAIL_PROVIDER=resend)
# Replace re_xxxxxxxxx with your real Resend API key.
RESEND_API_KEY=re_xxxxxxxxx

# SendGrid (for EMAIL_PROVIDER=sendgrid)
# Replace SG.xxxxxxxx with your real SendGrid API key.
SENDGRID_API_KEY=SG.xxxxxxxx

# Mailchimp Transactional / Mandrill (for EMAIL_PROVIDER=mailchimp)
# Replace your-mailchimp-transactional-api-key with your real API key.
MAILCHIMP_TRANSACTIONAL_API_KEY=your-mailchimp-transactional-api-key

# Postal HTTP API (for EMAIL_PROVIDER=postal)
# POSTAL_API_URL should be the Postal web base URL, not the full send endpoint.
# In Docker Compose, prefer the internal service URL. If you call Postal from outside
# Docker, replace this with your Traefik hostname or another reachable URL.
POSTAL_API_URL=http://postal-web:5000
POSTAL_SERVER_API_KEY=postal_server_api_key

# Listmonk API proxy
# LISTMONK_API_URL should be the Listmonk web base URL, not the full /api endpoint.
# In Docker Compose, prefer the internal service URL. If you call Listmonk from outside
# Docker, replace this with your Traefik hostname or another reachable URL.
LISTMONK_API_URL=http://listmonk-app:9000
LISTMONK_USERNAME=api_user
LISTMONK_PASSWORD=api_token

# SMTP (for nodemailer provider)
# For local Stalwart dev, set SMTP_HOST=localhost and SMTP_PORT=2587 after bootstrapping Stalwart.
SMTP_HOST=smtp.titan.email
SMTP_PORT=587
SMTP_USER=noreply@ifkafin.com
SMTP_PASS=

# Default sender address
DEFAULT_FROM=noreply@ifkafin.com

# JWT secret for dashboard auth (generate a strong random value for production)
JWT_SECRET=change-me-to-a-strong-random-secret

# Allowed email domains (comma-separated)
ALLOWED_DOMAINS=ifkafin.com,finueva.com,heilomeet.com

# Optional Postal local overlay / containerized Postal deployment.
# Override POSTAL_IMAGE if you want a specific Postal tag.
POSTAL_IMAGE=ghcr.io/postalserver/postal:latest
POSTAL_DB_NAME=postal
POSTAL_DB_ROOT_PASSWORD=postal
POSTAL_WEB_PROTOCOL=https
POSTAL_WEB_HOSTNAME=postal.example.com
POSTAL_SMTP_HOSTNAME=postal.example.com
POSTAL_MESSAGE_DB_PREFIX=postal

# Optional Postal DNS config for generated postal.yml.
# If you set any POSTAL_DNS_* value, POSTAL_DNS_MX_RECORDS,
# POSTAL_DNS_SPF_INCLUDE, and POSTAL_DNS_RETURN_PATH_DOMAIN are required.
# POSTAL_DNS_MX_RECORDS is a comma-separated list.
POSTAL_DNS_MX_RECORDS=mx1.postal.example.com,mx2.postal.example.com
POSTAL_DNS_SPF_INCLUDE=spf.postal.example.com
POSTAL_DNS_RETURN_PATH_DOMAIN=rp.postal.example.com
POSTAL_DNS_ROUTE_DOMAIN=routes.postal.example.com
POSTAL_DNS_TRACK_DOMAIN=track.postal.example.com

# Optional Listmonk local overlay / containerized Listmonk deployment.
LISTMONK_IMAGE=listmonk/listmonk:latest
LISTMONK_DB_USER=listmonk
LISTMONK_DB_PASSWORD=listmonk
LISTMONK_DB_NAME=listmonk
LISTMONK_ADMIN_USER=
LISTMONK_ADMIN_PASSWORD=
LISTMONK_TIMEZONE=Etc/UTC

# Optional Stalwart production mail stack overlay.
# These settings preconfigure PostgreSQL, MinIO, and Redis for the production overlay.
STALWART_IMAGE=stalwartlabs/stalwart:latest
STALWART_HOSTNAME=mail.example.com
STALWART_ADMIN_USER=admin
STALWART_ADMIN_PASSWORD=change-me-stalwart-admin
STALWART_ACME_ENABLED=false
STALWART_ACME_DIRECTORY=https://acme-v02.api.letsencrypt.org/directory
STALWART_ACME_CHALLENGE=tls-alpn-01
STALWART_ACME_CONTACT=postmaster@example.com
STALWART_ACME_DOMAINS=mail.example.com
STALWART_ACME_CACHE=%{BASE_PATH}%/etc/acme
STALWART_ACME_RENEW_BEFORE=30d
STALWART_ACME_DEFAULT=true
STALWART_DB_USER=stalwart
STALWART_DB_PASSWORD=stalwart
STALWART_DB_NAME=stalwart
STALWART_REDIS_PASSWORD=stalwart
STALWART_MINIO_ROOT_USER=stalwart
STALWART_MINIO_ROOT_PASSWORD=stalwart-minio
STALWART_MINIO_BUCKET=stalwart
STALWART_MINIO_REGION=us-east-1