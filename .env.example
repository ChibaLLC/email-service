# Database
DATABASE_URL=postgresql://email_service:email_service_pass@localhost:5432/email_service

# Redis
REDIS_URL=redis://localhost:6379

# Email Provider: nodemailer | resend | sendgrid
EMAIL_PROVIDER=nodemailer

# SMTP (for nodemailer provider)
SMTP_HOST=smtp.titan.email
SMTP_PORT=587
SMTP_USER=noreply@ifkafin.com
SMTP_PASS=

# Default sender address
DEFAULT_FROM=noreply@ifkafin.com

# JWT secret for dashboard auth (generate a strong random value for production)
JWT_SECRET=change-me-to-a-strong-random-secret

# Allowed email domains (comma-separated)
ALLOWED_DOMAINS=ifkafin.com,finueva.com,heilomeet.com